    <section class="grid grid-cols-4 gap-1.5" id="lista-productos">
    {{#each db}}
    <div class="bg-neutral-primary-soft block max-w-sm border border-default rounded-3xl shadow-xs">
        <img class="rounded-t-base" src={{this.image}} alt="" />
    <div class="p-6 text-center">
        </span>
            <h5 class="mt-3 mb-6 text-2xl font-semibold tracking-tight text-heading">Nombre: {{this.name}}</h5>
            <h5 class="mt-3 mb-6 text-2xl font-semibold tracking-tight text-heading">Precio: {{this.price}}</h5>
            <h5 class="mt-3 mb-6 text-2xl font-semibold tracking-tight text-heading">Descripción: {{this.description}}</h5>
            <h5 class="mt-3 mb-6 text-2xl font-semibold tracking-tight text-heading">Id: {{this.id}}</h5>
        <div class="flex flex-row gap-1.5 justify-center">
        <a href="/api/products/{{this.id}}" class="inline-flex items-center text-white bg-brand bg-blue-500 box-border border border-transparent rounded-3xl hover:bg-brand-strong focus:ring-4 focus:ring-brand-medium shadow-xs font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none">
